{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/index.html", "dest": "/index.html" },
    { "src": "/(.+\\.css)", "dest": "/$1" },
    { "src": "/(.+\\.js)", "dest": "/$1" },
    { "src": "/(.+\\.png)", "dest": "/$1" },
    { "src": "/(.+\\.ico)", "dest": "/$1" },
    { "src": "/(.*)", "dest": "server.js" }
  ]
}
